{
  "name": "suncodexclaw",
  "version": "1.0.0",
  "description": "Feishu Codex assistant with WebSocket bot runtime, image and voice ingestion, cloud-doc progress logs, and local attachment sending.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "feishu:ws": "node tools/feishu_ws_bot.js --account default",
    "feishu:ws:dry": "node tools/feishu_ws_bot.js --account default --dry-run",
    "feishu:ctl": "bash tools/feishu_bot_ctl.sh",
    "feishu:daily-report": "node tools/feishu_daily_report.js --account fei-ls",
    "feishu:start": "bash tools/feishu_bot_ctl.sh start all",
    "feishu:stop": "bash tools/feishu_bot_ctl.sh stop all",
    "feishu:restart": "bash tools/feishu_bot_ctl.sh restart all",
    "feishu:status": "bash tools/feishu_bot_ctl.sh status all",
    "feishu:install-launchagents": "bash tools/install_feishu_launchagents.sh install all",
    "feishu:launchagents:status": "bash tools/install_feishu_launchagents.sh status all",
    "weixin:login": "node tools/weixin_openclaw_bot.js --account default --login",
    "weixin:run": "node tools/weixin_openclaw_bot.js --account default",
    "weixin:run:once": "node tools/weixin_openclaw_bot.js --account default --once",
    "weixin:run:dry": "node tools/weixin_openclaw_bot.js --account default --dry-run --once"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "ffmpeg-static": "^5.3.0",
    "yaml": "^2.8.2"
  }
}
